// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ExerciseCategory {
  id         Int      @id @default(autoincrement())
  targetId   Int      @map("target_id")
  name       String
  isActive   Boolean  @default(true) @map("is_active")
  createDate DateTime @default(now()) @map("create_date")
  updateDate DateTime @default(now()) @updatedAt @map("update_date")

  TrainingRecords TrainingRecord[]
  TargetAreas     TargetArea       @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@map("exercise_categories")
}

model TrainingRecord {
  id         Int      @id @default(autoincrement())
  exerciseId Int      @map("exercise_id")
  userId     Int      @map("user_id")
  date       DateTime @db.Date
  weight     Float
  count      Int
  createDate DateTime @default(now()) @map("create_date")
  updateDate DateTime @default(now()) @updatedAt @map("update_date")

  // 外部キー制約(親のモデルが削除されたら、このレコードも一緒に削除(Cascade)される。)
  // [リレーションフィールドの名前(Prismaが使う仮想のプロパティ)] [リレーションの相手となるモデルの名前] @relation(fields: [外部キーとなるフィールド名], references: [主キーとなるフィールド名], onDelete: Cascade)
  // １対１: [単数形(キャメルケース)] [単数形(アッパーケース)]
  // １対多： [複数形(キャメルケース)] [単数形(アッパーケース)[]]
  // 多対１： [複数形(キャメルケース)] [単数形(アッパーケース)]
  // 多対多： [複数形(キャメルケース)] [単数形(アッパーケース)[]]
  exerciseCategories ExerciseCategory? @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([exerciseId])
  @@index([userId])
  @@map("training_records")
}

model TargetArea {
  id         Int      @id @default(autoincrement())
  name       String
  createDate DateTime @default(now()) @map("create_date")
  updateDate DateTime @default(now()) @updatedAt @map("update_date")

  ExerciseCategories ExerciseCategory[]

  @@map("target_areas")
}

model User {
  id         Int      @id @default(autoincrement())
  username   String
  email      String   @unique
  userId     String   @unique @map("user_id")
  password   String
  createDate DateTime @default(now()) @map("create_date")
  updateDate DateTime @default(now()) @updatedAt @map("update_date")

  // UserからTrainingRecordへのリレーションを定義(１ 対 多： User 対 TrainingRecord)
  trainingRecords TrainingRecord[]

  requesters Friendship[] @relation("Requester")
  approvers  Friendship[] @relation("Approver")

  @@map("users")
}

model Friendship {
  requesterUserId      Int                  @map("requester_user_id")
  // Userテーブルの中間テーブルとなるようにリレーションを定義
  requester            User                 @relation("Requester", fields: [requesterUserId], references: [id])
  approvalUserId       Int                  @map("approval_user_id")
  // Userテーブルの中間テーブルとなるようにリレーションを定義
  approver             User                 @relation("Approver", fields: [approvalUserId], references: [id])
  status               Int
  // FriendshipテーブルからApprovalFriendStatusテーブルへのリレーションを定義(多 対 1： ApprovalFriendStatus 対 Friendship)
  approvalFriendStatus ApprovalFriendStatus @relation(fields: [status], references: [id])
  createDate           DateTime             @default(now()) @map("create_date")
  updateDate           DateTime             @default(now()) @updatedAt @map("update_date")

  // 同じユーザー間の申請が重複しないようにユニーク制約を追加
  @@unique([requesterUserId, approvalUserId])
  @@map("friendships")
}

model ApprovalFriendStatus {
  id   Int    @id
  name String

  friendships Friendship[]
}
