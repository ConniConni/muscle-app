generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model mst_muscle_category {
  id    Int     @default(autoincrement()) @id
  name  String

  muscle_trainings  muscle_training[]
}

model muscle_training {
  id             Int        @default(autoincrement()) @id
  category_id    Int
  date           DateTime   @db.Date
  count          Int
  create_date    DateTime   @default(now())
  update_date    DateTime   @default(now()) @updatedAt

  mst_muscle_category  mst_muscle_category?   @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@index([category_id])
}